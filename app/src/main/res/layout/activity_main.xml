<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#666666">

    <View
        android:id="@+id/road"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_centerVertical="true"
        android:background="#333333" />

    <View
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_centerVertical="true"
        android:background="#FFFFFF"
        android:layout_marginTop="97.5dp" />

    <View
        android:id="@+id/finishLine"
        android:layout_width="10dp"
        android:layout_height="200dp"
        android:layout_centerVertical="true"
        android:layout_alignParentRight="true"
        android:background="#00FF00"
        android:layout_marginRight="20dp" />

    <ImageView
        android:id="@+id/car1"
        android:src="@drawable/orengecar1"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="85dp"
        android:contentDescription="Car 1" />

    <ImageView
        android:id="@+id/car2"
        android:src="@drawable/orangecar2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="185dp"
        android:contentDescription="Car 2" />

    <Button
        android:id="@+id/btnCar1"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="Оранжевая машина"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:layout_margin="20dp" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="21dp"
        android:layout_toEndOf="@+id/btnCar1"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:text="СТАРТ" />

    <Button
        android:id="@+id/reboot"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_above="@id/btnCar1"
        android:layout_marginStart="19dp"
        android:layout_marginEnd="1dp"
        android:layout_marginBottom="-81dp"
        android:layout_toStartOf="@+id/btnCar2"
        android:layout_toEndOf="@id/btnStart"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:text="ЗАНОВО" />

    <TextView
        android:id="@+id/tvWinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:text=""
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="20dp" />

</RelativeLayout>
